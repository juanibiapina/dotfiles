#!/usr/bin/env bash
#
# Summary: Run a fixed pipeline of interactive pi steps over a seed message
#
# Usage: {cmd} <message>
#
# Runs an ordered list of steps. Each step prepends its predefined prompt to the
# previous step's output and runs `pi` interactively. You drive advancement: run
# the `/next` command inside pi to capture the current session's last assistant
# message and move to the next step. Quitting pi without `/next` stops the loop.
# Step 1 is seeded with the user's message. The final step's output is printed to
# stdout.
#
# Three steps: (1) plan the message with the `plan` skill, (2) fact-check the
# plan and investigate alternatives with the `research` skill, emitting an
# extended plan, then (3) implement the plan with the `code` skill. Step 1's
# prompt mirrors agents/prompts/plan.md; keep the two in sync if that template
# changes.

set -uo pipefail

if [[ $# -eq 0 ]]; then
  echo "usage: pi-loop <message>" >&2
  exit 2
fi

steps=(
  "Use the \`plan\` skill."
  "Use the \`research\` skill to double-check all facts and investigate alternatives in the plan below. Then output an extended plan that incorporates all previous information along with your new findings."
  "Use the \`code\` skill to implement the plan below. Do not commit."
)

input="$*"

for prefix in "${steps[@]}"; do
  prompt="$prefix

$input"

  output_file="$(mktemp -t pi-loop.XXXXXX)"
  trap 'rm -f "$output_file"' EXIT

  PI_LOOP_OUTPUT="$output_file" pi "$prompt"

  if [[ ! -s "$output_file" ]]; then
    echo "pi-loop: no output captured (run /next to advance, or the step was aborted)" >&2
    rm -f "$output_file"
    exit 1
  fi

  input="$(cat "$output_file")"
  rm -f "$output_file"
done

printf '%s\n' "$input"

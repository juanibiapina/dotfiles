#!/usr/bin/env bash
#
# Summary: Toggle lazygit pager between deltoids and delta
#
# Usage: {cmd}
#
# Switches the pager in lazygit config between "deltoids" and "delta".
# Refocus lazygit window for the change to take effect.

set -e

config="$HOME/.config/lazygit/config.yml"

# Resolve symlink to get actual file
if [[ -L "$config" ]]; then
  config=$(readlink -f "$config")
fi

if [[ ! -f "$config" ]]; then
  echo "Config not found: $config" >&2
  exit 1
fi

if grep -q 'pager: deltoids$' "$config"; then
  sed -i '' 's/pager: deltoids$/pager: delta --dark --paging=never/' "$config"
  echo "Switched to: delta"
elif grep -q 'pager: delta --dark --paging=never' "$config"; then
  sed -i '' 's/pager: delta --dark --paging=never/pager: deltoids/' "$config"
  echo "Switched to: deltoids"
else
  echo "Unknown pager configuration" >&2
  exit 1
fi
